{
  "name": "ens-free-trial-subdomain-registrar",
  "version": "1.0.0",
  "private": true,
  "description": "Free 30-day ENS subname registrar with no child grace period and no owner renewals.",
  "type": "module",
  "engines": {
    "node": ">=22.10.0"
  },
  "scripts": {
    "clean": "hardhat clean",
    "build": "hardhat build --build-profile production",
    "build:dev": "hardhat build",
    "test": "hardhat test --build-profile production",
    "deploy:mainnet": "hardhat run scripts/deploy-mainnet.ts --build-profile production --network mainnet",
    "setup:parent:mainnet": "hardhat run scripts/approve-and-setup-parent.ts --build-profile production --network mainnet",
    "register:mainnet": "hardhat run scripts/register-subname.ts --build-profile production --network mainnet",
    "verify:mainnet": "hardhat verify --build-profile production --network mainnet",
    "check": "npm run clean && npm run build && npm test"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@types/node": "^22.10.5",
    "dotenv": "^16.4.7",
    "hardhat": "^3.0.0",
    "typescript": "^5.7.2"
  }
}

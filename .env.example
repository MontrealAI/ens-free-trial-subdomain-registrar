# Required for mainnet scripts
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Required safety gate for state-changing mainnet scripts
MAINNET_CONFIRM=I_UNDERSTAND_MAINNET

# Optional: override ENS NameWrapper (defaults to mainnet NameWrapper)
ENS_NAME_WRAPPER=0xD4416b13d2b3a9aBae7AcD5D6C2BbDBE25686401

# Required for parent setup and registration scripts
REGISTRAR_ADDRESS=0xYourRegistrarAddress
PARENT_NAME=example.eth
# Flagship example: PARENT_NAME=alpha.agent.agi.eth
# PARENT_NODE=0x... (optional alternative to PARENT_NAME)

# Registration defaults
LABEL=trialpass8
# Flagship examples: LABEL=12345678 or LABEL=ethereum (single label only)
NEW_OWNER=0xRecipientAddress
RESOLVER=0x0000000000000000000000000000000000000000
OWNER_CONTROLLED_FUSES=0
RECORDS_JSON=[]


# Optional preflight inputs for doctor script
# npm run doctor:mainnet -- --registrar 0x... --parent-name example.eth --label trialpass8
# Parent setup default
PARENT_ACTION=activate
# Legacy fallback (only if PARENT_ACTION is unset): ACTIVE=true|false

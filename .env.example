# Required for deployment / scripts
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0xyourprivatekey
ETHERSCAN_API_KEY=your_etherscan_key

# Deployed registrar address (set after deploy)
REGISTRAR_ADDRESS=0xYourRegistrarAddress

# ENS NameWrapper (mainnet default)
ENS_NAME_WRAPPER=0xD4416b13d2b3a9aBae7AcD5D6C2BbDBE25686401

# Parent selection (set one)
PARENT_NAME=example.eth
# PARENT_NODE=0x...

# Registration inputs
LABEL=trialpass8
NEW_OWNER=0xRecipientAddress
RESOLVER=0x0000000000000000000000000000000000000000
OWNER_CONTROLLED_FUSES=0
RECORDS_JSON=[]

# Parent activation toggle
ACTIVE=true
